#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x624d2e019cf0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x624d2e01bf80 .scope module, "testbench" "testbench" 3 3;
 .timescale 0 0;
v0x624d2e041960_0 .net "ins", 0 31, L_0x624d2e041e40;  1 drivers
v0x624d2e041a20_0 .var "pc", 0 31;
S_0x624d2e01c110 .scope module, "inst" "instruction_memory" 3 8, 4 7 0, S_0x624d2e01bf80;
 .timescale 0 0;
    .port_info 0 /INPUT 32 "pc";
    .port_info 1 /OUTPUT 32 "instruction";
L_0x624d2e041e40 .functor BUFZ 32, L_0x624d2e041be0, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>;
v0x624d2dff3490_0 .net *"_ivl_2", 31 0, L_0x624d2e041be0;  1 drivers
v0x624d2e0413b0_0 .net *"_ivl_4", 4 0, L_0x624d2e041cb0;  1 drivers
L_0x76d58489d018 .functor BUFT 1, C4<0>, C4<0>, C4<0>, C4<0>;
v0x624d2e041490_0 .net *"_ivl_7", 0 0, L_0x76d58489d018;  1 drivers
v0x624d2e041550_0 .net "instruction", 31 0, L_0x624d2e041e40;  alias, 1 drivers
v0x624d2e041630 .array "memory", 9 0, 31 0;
v0x624d2e041740_0 .net "pc", 31 0, v0x624d2e041a20_0;  1 drivers
v0x624d2e041820_0 .net "rom_addr", 3 0, L_0x624d2e041ac0;  1 drivers
L_0x624d2e041ac0 .part v0x624d2e041a20_0, 2, 4;
L_0x624d2e041be0 .array/port v0x624d2e041630, L_0x624d2e041cb0;
L_0x624d2e041cb0 .concat [ 4 1 0 0], L_0x624d2e041ac0, L_0x76d58489d018;
    .scope S_0x624d2e01c110;
T_0 ;
    %vpi_call/w 4 17 "$readmemb", "program.txt", v0x624d2e041630, 32'sb00000000000000000000000000000000, 32'sb00000000000000000000000000001001 {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x624d2e01bf80;
T_1 ;
    %vpi_call/w 3 11 "$dumpfile", "inverter.vcd" {0 0 0};
    %vpi_call/w 3 12 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x624d2e01bf80 {0 0 0};
    %end;
    .thread T_1;
    .scope S_0x624d2e01bf80;
T_2 ;
    %vpi_call/w 3 17 "$monitor", $time, " pc= %b, instruction: %b", v0x624d2e041a20_0, v0x624d2e041960_0 {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x624d2e041a20_0, 0, 32;
    %delay 5, 0;
    %load/vec4 v0x624d2e041a20_0;
    %addi 4, 0, 32;
    %store/vec4 v0x624d2e041a20_0, 0, 32;
    %delay 5, 0;
    %vpi_call/w 3 22 "$finish" {0 0 0};
    %end;
    .thread T_2;
# The file index is used to find the file name in the following table.
:file_names 5;
    "N/A";
    "<interactive>";
    "-";
    "testbench.v";
    "./instruction_memory.v";
